---
import Analytics from "@vercel/analytics/astro";

import type { LandingCopy, Locale } from "../content";
import { buildSeo, buildStructuredData } from "../lib/seo";
import "../styles/global.css";

interface Props {
  locale: Locale;
  meta: LandingCopy["meta"];
  features?: LandingCopy["features"];
  faq?: LandingCopy["faq"];
  softwareVersion?: string;
  indexable?: boolean;
}

const {
  locale,
  meta,
  features = [],
  faq,
  softwareVersion = "",
  indexable = true,
} = Astro.props;
const seo = buildSeo(locale, meta);
const skipLabel = locale === "en" ? "Skip to content" : "Saltar al contenido";
const ogLocale = locale === "en" ? "en_US" : "es_AR";
const alternateOgLocale = locale === "en" ? "es_AR" : "en_US";
const imageAlt =
  locale === "en"
    ? "memo, local-first memory for AI agents"
    : "memo, memoria local para agentes de IA";
const structuredData =
  indexable && faq
    ? JSON.stringify(
        buildStructuredData({
          locale,
          meta,
          features,
          faq,
          softwareVersion,
        }),
      ).replaceAll("<", "\\u003c")
    : undefined;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta
      name="robots"
      content={indexable
        ? "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
        : "noindex, follow"}
    />
    <meta name="author" content="Fernando Ferrari" />
    <meta name="application-name" content="memo" />
    <meta name="theme-color" content="#07050d" />
    <meta name="color-scheme" content="dark" />
    {
      indexable && (
        <>
          <link rel="canonical" href={seo.canonical} />
          {seo.alternates.map(({ lang, href }) => (
            <link rel="alternate" hreflang={lang} href={href} />
          ))}
          <link
            rel="sitemap"
            type="application/xml"
            href="/sitemap-index.xml"
          />
        </>
      )
    }
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {
      indexable && (
        <>
          <meta property="og:type" content="website" />
          <meta property="og:site_name" content="memo" />
          <meta property="og:locale" content={ogLocale} />
          <meta property="og:locale:alternate" content={alternateOgLocale} />
          <meta property="og:title" content={seo.title} />
          <meta property="og:description" content={seo.description} />
          <meta property="og:url" content={seo.canonical} />
          <meta property="og:image" content={seo.ogImage.url} />
          <meta property="og:image:secure_url" content={seo.ogImage.url} />
          <meta property="og:image:width" content={String(seo.ogImage.width)} />
          <meta
            property="og:image:height"
            content={String(seo.ogImage.height)}
          />
          <meta property="og:image:type" content={seo.ogImage.type} />
          <meta property="og:image:alt" content={imageAlt} />

          <meta name="twitter:card" content="summary_large_image" />
          <meta name="twitter:title" content={seo.title} />
          <meta name="twitter:description" content={seo.description} />
          <meta name="twitter:image" content={seo.ogImage.url} />
          <meta name="twitter:image:alt" content={imageAlt} />

          <script
            is:inline
            type="application/ld+json"
            set:html={structuredData}
          />
        </>
      )
    }
  </head>
  <body>
    <a class="skip-link button button--primary" href="#main-content"
      >{skipLabel}</a
    >
    <slot name="header" />
    <slot />
    <Analytics />

    <script>
      import.meta.glob(["../scripts/interactions.ts", "../scripts/motion.ts"], {
        eager: true,
      });
    </script>
  </body>
</html>
