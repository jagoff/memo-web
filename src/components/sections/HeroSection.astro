---
import type { LandingCopy } from "../../content";
import MemoryGraph from "../visualizations/MemoryGraph.astro";

interface Props {
  copy: LandingCopy["hero"];
}

const { copy } = Astro.props;
const agents = ["Claude Code", "Codex", "Cursor", "Devin", "Cline", "MCP"];
---

<section class="hero" data-scene="hero" aria-labelledby="hero-title">
  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1 class="display" id="hero-title">{copy.title}</h1>
      <p class="hero-body">{copy.body}</p>

      <div class="hero-actions">
        <a class="button button--primary" href="#install">{copy.install}</a>
        <a
          class="button button--secondary"
          href="https://github.com/jagoff/memo"
        >
          <svg
            class="github-mark"
            viewBox="0 0 24 24"
            aria-hidden="true"
            focusable="false"
          >
            <path
              fill="currentColor"
              d="M12 1C5.923 1 1 5.923 1 12c0 4.867 3.149 8.979 7.521 10.436.55.096.756-.233.756-.522 0-.262-.013-1.128-.013-2.049-2.764.509-3.479-.674-3.699-1.292-.124-.317-.66-1.293-1.127-1.554-.385-.207-.936-.715-.014-.729.866-.014 1.485.797 1.691 1.128.99 1.663 2.571 1.196 3.204.907.096-.715.385-1.196.701-1.471-2.448-.275-5.005-1.224-5.005-5.431 0-1.197.426-2.186 1.128-2.956-.111-.275-.496-1.402.11-2.915 0 0 .921-.288 3.024 1.128a10.193 10.193 0 0 1 2.75-.371c.936 0 1.871.123 2.75.371 2.104-1.43 3.025-1.128 3.025-1.128.605 1.513.221 2.64.111 2.915.701.77 1.127 1.747 1.127 2.956 0 4.22-2.571 5.156-5.019 5.431.399.344.743 1.004.743 2.035 0 1.471-.014 2.654-.014 3.025 0 .289.206.632.756.522C19.851 20.979 23 16.854 23 12c0-6.077-4.922-11-11-11Z"
            ></path>
          </svg>
          {copy.github}
        </a>
      </div>

      <ul class="agent-list">
        {
          agents.map((agent) => (
            <li>
              <span aria-hidden="true" />
              {agent}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="hero-graph">
      <MemoryGraph idPrefix="hero" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: max(44rem, calc(100svh - 5rem));
    overflow: clip;
    border-bottom: 1px solid
      color-mix(in srgb, var(--paper-200) 10%, transparent);
    background:
      radial-gradient(
        circle at 76% 46%,
        color-mix(in srgb, var(--violet-700) 24%, transparent),
        transparent 42%
      ),
      linear-gradient(180deg, var(--ink-950), var(--ink-900));
  }

  .hero::before {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--paper-200) 4%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--paper-200) 4%, transparent) 1px,
        transparent 1px
      );
    background-size: 5rem 5rem;
    content: "";
    mask-image: linear-gradient(to bottom, black, transparent 88%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: inherit;
    align-items: center;
    gap: clamp(2rem, 5vw, 6rem);
    grid-template-columns: minmax(0, 1.05fr) minmax(20rem, 0.95fr);
    padding-block: clamp(4.5rem, 10vw, 8rem);
  }

  .hero-copy {
    position: relative;
    z-index: 2;
  }

  .hero-copy .eyebrow {
    margin: 0 0 var(--space-6);
  }

  .hero-copy .display {
    max-width: 8.5ch;
  }

  .hero-body {
    max-width: 35rem;
    margin: var(--space-8) 0 0;
    color: var(--paper-200);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .button--secondary {
    border-color: color-mix(in srgb, var(--paper-200) 34%, transparent);
    color: var(--paper-50);
    background: color-mix(in srgb, var(--ink-800) 72%, transparent);
  }

  .button--secondary:hover {
    border-color: var(--signal-300);
  }

  .github-mark {
    width: 1.15rem;
    height: 1.15rem;
    flex: none;
  }

  .agent-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: 0;
    margin: var(--space-12) 0 0;
    list-style: none;
  }

  .agent-list li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--paper-200) 15%, transparent);
    border-radius: 999px;
    color: var(--muted-400);
    background: color-mix(in srgb, var(--ink-800) 68%, transparent);
    font: 650 0.72rem/1 var(--font-mono);
  }

  .agent-list span {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--signal-300);
    box-shadow: 0 0 0.75rem
      color-mix(in srgb, var(--signal-300) 70%, transparent);
  }

  .hero-graph {
    width: min(48vw, 42rem);
    justify-self: end;
  }

  @media (max-width: 840px) {
    .hero-inner {
      grid-template-columns: 1fr;
      padding-top: clamp(4rem, 12vw, 6rem);
    }

    .hero-copy .display {
      max-width: 10ch;
    }

    .hero-graph {
      width: min(100%, 34rem);
      justify-self: center;
      margin-top: calc(var(--space-8) * -1);
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: auto;
    }

    .hero-inner {
      gap: var(--space-12);
      padding-block: var(--space-16);
    }

    .hero-actions {
      display: grid;
    }

    .agent-list {
      margin-top: var(--space-8);
    }

    .hero-graph {
      margin-top: 0;
    }
  }
</style>
