---
import type { LandingCopy } from "../../content";

interface Props {
  copy: LandingCopy["featuresHeading"];
  features: LandingCopy["features"];
  id?: string;
}

const { copy, features, id } = Astro.props;

if (features.length !== 4) {
  throw new Error("FeatureRail requires exactly four typed features.");
}
---

<section
  class="feature-rail"
  id={id}
  data-scene="features"
  aria-labelledby="features-title"
>
  <div class="container">
    <div class="features-heading">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h2 id="features-title">{copy.title}</h2>
      <p class="features-body">{copy.body}</p>
    </div>

    <div class="feature-grid">
      {
        features.map((feature, index) => (
          <article data-feature-card data-feature-id={feature.id}>
            <div class="feature-meta">
              <span aria-hidden="true">
                {String(index + 1).padStart(2, "0")}
              </span>
              <svg
                class={`feature-mark feature-mark--${feature.id}`}
                viewBox="0 0 64 64"
                aria-hidden="true"
                focusable="false"
                role="presentation"
              >
                <circle cx="32" cy="32" r="24" />
                {feature.id === "time-machine" && (
                  <path d="M32 18V33L42 39M19 21L13 22L14 16" />
                )}
                {feature.id === "contradictions" && (
                  <path d="M19 22L45 42M45 22L19 42M17 32H47" />
                )}
                {feature.id === "capture" && (
                  <path d="M18 25V18H25M39 18H46V25M46 39V46H39M25 46H18V39M25 32H39" />
                )}
                {feature.id === "cross-agent" && (
                  <path d="M20 23L32 32L44 23M20 41L32 32L44 41" />
                )}
              </svg>
            </div>

            <div>
              <h3>{feature.title}</h3>
              <p>{feature.body}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .feature-rail {
    position: relative;
    padding-block: var(--space-section);
    overflow: clip;
    border-block: 1px solid
      color-mix(in srgb, var(--paper-200) 10%, transparent);
    background: var(--ink-900);
  }

  .features-heading {
    display: grid;
    max-width: 62rem;
    gap: var(--space-6);
  }

  .features-heading .eyebrow,
  .features-heading h2,
  .features-body {
    margin: 0;
  }

  .features-heading h2 {
    max-width: 11ch;
    font: 500 clamp(3rem, 7vw, 6.5rem) / 0.95 var(--font-display);
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .features-body {
    max-width: 48rem;
    color: var(--paper-200);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
  }

  .feature-grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: clamp(3rem, 8vw, 7rem);
  }

  article {
    display: grid;
    min-height: 22rem;
    align-content: space-between;
    gap: var(--space-12);
    padding: clamp(1.5rem, 4vw, 3rem);
    border: 1px solid color-mix(in srgb, var(--paper-200) 14%, transparent);
    border-radius: var(--radius-md);
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--ink-800) 98%, transparent),
      color-mix(in srgb, var(--violet-700) 16%, var(--ink-900))
    );
  }

  .feature-meta {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    color: var(--signal-300);
    font: 700 0.75rem/1 var(--font-mono);
    letter-spacing: 0.14em;
  }

  .feature-mark {
    width: 4rem;
    height: 4rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  h3,
  article p {
    margin: 0;
  }

  h3 {
    font: 520 clamp(1.7rem, 3vw, 2.55rem) / 1.05 var(--font-display);
    letter-spacing: -0.035em;
  }

  article p {
    max-width: 36rem;
    margin-top: var(--space-4);
    color: var(--paper-200);
    font-size: 1rem;
  }

  @media (max-width: 720px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }

    article {
      min-height: 17rem;
    }
  }
</style>
