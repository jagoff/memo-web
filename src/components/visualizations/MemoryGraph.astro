<style>
  .memory-graph {
    position: relative;
    width: 100%;
    max-width: 40rem;
    margin-inline: auto;
    aspect-ratio: 1;
    filter: drop-shadow(var(--shadow-glow));
  }

  svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .graph-backdrop {
    fill: url("#memory-bloom");
  }

  .graph-edge {
    stroke: color-mix(in srgb, var(--signal-300) 54%, var(--violet-400));
    stroke-width: 1.25;
    vector-effect: non-scaling-stroke;
  }

  .graph-node {
    fill: var(--signal-300);
    filter: url("#node-bloom");
    stroke: color-mix(in srgb, var(--paper-50) 72%, transparent);
    stroke-width: 1;
    transform-box: fill-box;
    transform-origin: center;
  }

  .memo-mark {
    fill: none;
    filter: url("#node-bloom");
    stroke: var(--paper-50);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 10;
  }
</style>
